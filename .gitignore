# 1. Dependencies
# This hides the massive folders created by 'npm install' in both Frontend and Backend
node_modules/
.pnpm-store/

# 2. Vite & Build Outputs
# Hides the auto-generated production code
dist/
dist-ssr/
*.local

# 3. TypeScript Specific
# Hides the TS build info which can show old timestamps
*.tsbuildinfo

# 4. Environment Secrets (CRITICAL)
# This keeps your Database URLs and API Keys off GitHub
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 5. Editor & System Junk
# Hides files created by VS Code, IntelliJ, or Windows/Mac systems
.vscode/
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 6. Logs
# Hides error reports that get messy during a hackathon
core
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*